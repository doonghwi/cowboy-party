{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      ".read": true,
      ".indexOn": "createdAt",
      "$code": {
        ".write": true,
        "title": { ".validate": "newData.isString() && newData.val().length <= 24" },
        "hostName": { ".validate": "newData.isString() && newData.val().length <= 16" },
        "capacity": { ".validate": "newData.isNumber() && newData.val() >= 2 && newData.val() <= 6" },
        "players": {
          "$slot": {
            "name": { ".validate": "newData.isString() && newData.val().length <= 16" }
          }
        }
      }
    },

    "users": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid == $uid",
        "name": { ".validate": "newData.isString() && newData.val().length <= 24" },
        "coins": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "equipped": { ".validate": "newData.isNumber()" },
        "dailyStreak": { ".validate": "newData.isNumber()" }
      }
    },

    "seasons": {
      ".read": true,
      "$sid": {
        ".indexOn": "pts",
        "$uid": {
          ".write": "newData.exists() && auth != null && auth.uid == $uid",
          "name": { ".validate": "newData.isString() && newData.val().length <= 24" },
          "pts": { ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || newData.val() >= data.val())" },
          "$other": { ".validate": false }
        }
      }
    },

    "build": { ".read": true, ".write": true },
    "stats": { ".read": true, ".write": true }
  }
}
