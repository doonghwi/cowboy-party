{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      ".read": true,
      ".indexOn": "createdAt",
      "$code": {
        ".write": "auth != null",
        "title": { ".validate": "newData.isString() && newData.val().length <= 24" },
        "hostName": { ".validate": "newData.isString() && newData.val().length <= 16" },
        "capacity": { ".validate": "newData.isNumber() && newData.val() >= 2 && newData.val() <= 6" },
        "createdAt": { ".validate": "newData.isNumber() && (!data.exists() || data.val() == newData.val())" },
        "score": {
          "$slot": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || newData.val() >= data.val())"
          }
        },
        "players": {
          "$slot": {
            "name": { ".validate": "newData.isString() && newData.val().length <= 16" }
          }
        }
      }
    },

    "users": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid == $uid",
        "name": { ".validate": "newData.isString() && newData.val().length <= 24" },
        "coins": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "equipped": { ".validate": "newData.isNumber()" },
        "dailyStreak": { ".validate": "newData.isNumber()" }
      }
    },

    "seasons": {
      ".read": true,
      "$sid": {
        ".indexOn": "pts",
        "$uid": {
          ".write": "newData.exists() && auth != null && auth.uid == $uid",
          "name": { ".validate": "newData.isString() && newData.val().length <= 24" },
          "pts": { ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() ? newData.val() <= 60 : (newData.val() >= data.val() && newData.val() <= data.val() + 60))" },
          "$other": { ".validate": false }
        }
      }
    },

    "giftcodes": {
      ".read": true,
      "$code": {
        "claimedBy": {
          ".write": "!data.exists() || data.val() == newData.val()",
          ".validate": "newData.isString() && newData.val().length <= 64"
        }
      }
    },

    "nicknames": {
      ".read": true,
      "$name": {
        ".write": "auth != null && (!data.exists() || data.val() == auth.uid)",
        ".validate": "!newData.exists() || newData.val() == auth.uid"
      }
    },

    "build": { ".read": true, ".write": false },
    "stats": { ".read": true, ".write": false },
    "charstats": {
      ".read": true,
      ".write": true,
      "$idx": {
        "games": { ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || newData.val() >= data.val())" },
        "wins": { ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || newData.val() >= data.val())" },
        "$other": { ".validate": false }
      }
    }
  }
}
